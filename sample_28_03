# syntax=docker/dockerfile:1

# Generic multi-stage Docker build template
# Override values at build time, e.g.:
# docker build --build-arg RUNTIME_IMAGE=python:3.12-slim --build-arg APP_DIR=/app .

ARG BUILD_IMAGE=alpine:3.20
ARG RUNTIME_IMAGE=alpine:3.20
ARG APP_DIR=/app

FROM ${BUILD_IMAGE} AS builder
ARG APP_DIR
WORKDIR ${APP_DIR}

# Copy the full application source for build steps
COPY . .

# Placeholder build step (replace with your build command)
# Examples:
# - npm ci && npm run build
# - go build -o /out/app ./cmd/app
# - pip install --prefix=/install -r requirements.txt
RUN mkdir -p /out && cp -r . /out/app

FROM ${RUNTIME_IMAGE} AS runtime
ARG APP_DIR
WORKDIR ${APP_DIR}

# Copy only the build artifacts from the builder stage
COPY --from=builder /out/app .

# Expose a common app port (adjust as needed)
EXPOSE 8080

# Generic default command (replace with your runtime entrypoint)
CMD ["sh", "-c", "echo 'Replace CMD with your app start command' && sleep infinity"]
